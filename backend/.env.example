# Database — use the asyncpg connection string from Supabase project settings
# Format: postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Supabase project credentials (Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# JWT for signing approval tokens (separate from Supabase — generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-for-approval-tokens

# Email notifications via Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key

# Environment: "development" or "production"
ENVIRONMENT=development
